# Copy this file to .env before local development.
# Never commit real secrets or production database URLs.

DATABASE_URL="file:./dev.db"

# Used by admin or import/export features. Change before deployment.
ADMIN_PASSWORD="change-me-before-deploy"

# Public app name displayed in the browser.
NEXT_PUBLIC_APP_NAME="AI学习网站"

# Optional: restrict upload size in future file upload modules.
MAX_UPLOAD_SIZE_MB="50"

# Optional: comma-separated origins allowed by future API routes.
# Example: https://example.com,https://admin.example.com
ALLOWED_ORIGINS="http://localhost:3000"
